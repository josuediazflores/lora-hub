{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LoRA Hub",
  "version": "0.1.0",
  "identifier": "com.lorahub.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LoRA Hub",
        "width": 1100,
        "height": 760,
        "minWidth": 720,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: https:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost ws://localhost:* wss://localhost:* http://localhost:* https://api.search.brave.com https://html.duckduckgo.com https://huggingface.co https://*.hf.co https://cdn-lfs.hf.co; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/python/**/*",
      "resources/sidecar/*.py"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://updates.lorahub.app/{{target}}/{{arch}}/{{current_version}}"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE1N0YxN0Y2RDMyRjU1Q0IKUldUTFZTL1Q5aGQvRmQrS0EwWEx5OEZ1Mm1VYlJIRFZMQ3Fkc2dubVc2dVFBRUw4OWRIb3k1WUQK"
    }
  }
}
